<script>
// Findings data
const findings = ${findings_json};

// Render findings
function renderFindings(list) {
    const c = document.getElementById('findings-container');
    if (!list.length) {
        c.innerHTML = '<div class="no-findings"><div class="icon">✅</div><div>Tidak ada temuan pada filter ini</div></div>';
        return;
    }
    const levelOrder = {CRITICAL:0, HIGH:1, MEDIUM:2, LOW:3, INFO:4};
    list.sort((a,b) => (levelOrder[a.level]||4) - (levelOrder[b.level]||4));
    c.innerHTML = list.map((f, i) => \`
        <div class="finding \${f.level}" data-level="\${f.level}" data-title="\${f.title.toLowerCase()}" data-plugin="\${f.plugin}">
            <div class="finding-header">
                <span class="badge \${f.level}">\${f.level}</span>
                <span class="plugin-tag">\${f.plugin || 'unknown'}</span>
            </div>
            <div class="finding-title">\${f.title}</div>
            \${f.resource ? '<div class="finding-resource">→ ' + f.resource + '</div>' : ''}
        </div>
    \`).join('');
}

// Init render
renderFindings(findings);

// Filter
function filterFindings(btn) {
    const level = btn.dataset.level;
    document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    const filtered = level === 'ALL' ? findings : findings.filter(f => f.level === level);
    renderFindings(filtered);
}

// Search
function searchFindings(q) {
    const ql = q.toLowerCase();
    const activeLevel = document.querySelector('.filter-btn.active')?.dataset.level || 'ALL';
    let list = activeLevel === 'ALL' ? findings : findings.filter(f => f.level === activeLevel);
    if (ql) list = list.filter(f => f.title.toLowerCase().includes(ql) || (f.resource||'').toLowerCase().includes(ql) || (f.plugin||'').toLowerCase().includes(ql));
    renderFindings(list);
}

// Tab switch
function switchTab(name, btn) {
    document.querySelectorAll('.tab-content').forEach(t => t.classList.remove('active'));
    document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
    document.getElementById('tab-' + name).classList.add('active');
    if (btn) btn.classList.add('active');
}

// Collapsible
function toggleColl(id, header) {
    const body = document.getElementById(id);
    const isOpen = body.style.display === 'block';
    body.style.display = isOpen ? 'none' : 'block';
    header.classList.toggle('open', !isOpen);
}
</script>
</body>
</html>
HTMLEOF

    ok "HTML Report → $REPORT_HTML"
}

# ── MENU ─────────────────────────────────────────────────────────
show_menu() {
    banner
    echo -e "${GREEN}${BOLD}  ┏━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┓${NC}"
    echo -e "${GREEN}${BOLD}  ┃  PILIH OPERASI                                            ┃${NC}"
    echo -e "${GREEN}${BOLD}  ┗━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┛${NC}"
    echo ""
    echo -e "  ${WHITE}[1]${NC}  🚀  FULL SCAN — Semua plugin  ${DIM}(recommended)${NC}"
    echo -e "  ${WHITE}[2]${NC}  ⚡  QUICK SCAN — Scan cepat"
    echo -e "  ${WHITE}[3]${NC}  🔍  DNS & Subdomain only"
    echo -e "  ${WHITE}[4]${NC}  🔒  TLS / SSL only"
    echo -e "  ${WHITE}[5]${NC}  📋  Headers only"
    echo -e "  ${WHITE}[6]${NC}  🕵️   Stealth scan"
    echo -e "  ${WHITE}[7]${NC}  📊  Compliance scan (SARIF output)"
    echo -e "  ${WHITE}[8]${NC}  📂  Buka laporan terakhir di browser"
    echo -e "  ${WHITE}[9]${NC}  🎯  Ganti target"
    echo -e "  ${WHITE}[0]${NC}  ❌  Keluar"
    echo ""
    echo -e "  ${DIM}Target(s) : ${CYAN}${TARGETS[*]}${NC}"
    echo -e "  ${DIM}Stealth   : $([ "$STEALTH_MODE" = "true" ] && echo -e "${GREEN}ON${NC}" || echo -e "${RED}OFF${NC}") ${DIM}| Proxy: ${PROXY:-none}${NC}"
    echo ""
    echo -ne "  ${GREEN}nightcrawler${NC} > "
}

main() {
    # Cek binary
    if ! command -v "$NC_BIN" &>/dev/null; then
        echo -e "${RED}[!] nightcrawler binary tidak ditemukan di PATH.${NC}"
        echo -e "${YELLOW}[i] Install dulu: curl -sSL https://raw.githubusercontent.com/1607-NetEnginee/NightCrawler/main/scripts/install.sh | bash${NC}"
        exit 1
    fi

    mkdir -p "$OUTPUT_DIR"
    input_setup

    while true; do
        show_menu; read -r CHOICE
        case "$CHOICE" in
            1) run_scan "default" ;;
            2) run_scan "quick" ;;
            3) run_scan "default" "dns,crtsh" ;;
            4) run_scan "default" "tls" ;;
            5) run_scan "default" "headers" ;;
            6) STEALTH_MODE="true"; run_scan "stealth" ;;
            7) run_scan "compliance" ;;
            8)
                local last_report
                last_report=$(find "$OUTPUT_DIR" -name "NIGHTCRAWLER_REPORT.html" -newer "$OUTPUT_DIR" 2>/dev/null | sort | tail -1)
                if [ -n "$last_report" ]; then
                    xdg-open "$last_report" 2>/dev/null || warn "Tidak bisa buka browser. Path: $last_report"
                else
                    warn "Belum ada laporan. Jalankan scan dulu."
                fi
                ;;
            9)
                TARGETS=()
                echo ""
                echo -e "  ${DIM}Masukkan target baru. Ketik ${WHITE}done${DIM} jika selesai.${NC}"; echo ""
                local idx=1
                while true; do
                    echo -ne "  ${CYAN}[target-$idx]${NC} > "; read -r raw
                    [[ "$raw" =~ ^(done|selesai|q|)$ ]] && break
                    local clean; clean=$(sanitize_domain "$raw")
                    [ -n "$clean" ] && { TARGETS+=("$clean"); ok "Target: $clean"; idx=$((idx+1)); } || warn "Format tidak valid."
                done
                [ ${#TARGETS[@]} -eq 0 ] && warn "Target tidak diubah."
                ;;
            0)
                echo ""
                glitch_text "NIGHTCRAWLER signing off."
                echo ""; exit 0
                ;;
            *) fail "Pilihan tidak valid." ;;
        esac
        echo ""
        echo -ne "  ${CYAN}[>]${NC} Kembali ke menu? [Y/n]: "; read -r back
        [[ "$back" =~ ^[Nn]$ ]] && { glitch_text "NIGHTCRAWLER signing off."; echo ""; exit 0; }
    done
}

main "$@"
