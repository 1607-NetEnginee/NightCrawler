#!/bin/bash
# ════════════════════════════════════════════════════════════════════
#  NIGHTCRAWLER v7.0 — Interactive UI Wrapper
#  Author: 1607-NetEnginee / Cyberoutcast
#
#  Wrapper interaktif untuk nightcrawler v7.0 binary.
#  Menyediakan wizard input, menu, dan laporan HTML interaktif.
#
#  Install:
#    sudo cp nightcrawler-ui /usr/local/bin/nightcrawler-ui
#    sudo chmod +x /usr/local/bin/nightcrawler-ui
#    sudo nightcrawler-ui
# ════════════════════════════════════════════════════════════════════
set -o pipefail

# ── GLOBALS ─────────────────────────────────────────────────────
NC_BIN="${NC_BIN:-nightcrawler}"
OUTPUT_DIR="${OUTPUT_DIR:-$HOME/nightcrawler-reports}"
TIMESTAMP=$(date +"%Y%m%d_%H%M%S")
OPERATOR_NAME=""
INSTANSI_NAME=""
TARGETS=()
STEALTH_MODE="true"
PROXY=""
REPORT_DIR=""
SCAN_LOG=""

RISK_CRITICAL=0
RISK_HIGH=0
RISK_MEDIUM=0
RISK_LOW=0
RISK_INFO=0
declare -a FINDINGS_DB=()

# ── COLORS ──────────────────────────────────────────────────────
RED='\033[0;31m'    GREEN='\033[0;32m'   YELLOW='\033[1;33m'
BLUE='\033[0;34m'   CYAN='\033[0;36m'    MAGENTA='\033[0;35m'
WHITE='\033[1;37m'  BOLD='\033[1m'       DIM='\033[2m'
NC='\033[0m'

# ── UI HELPERS ───────────────────────────────────────────────────
ok()   { echo -e "  ${GREEN}[✓]${NC} $1"; }
warn() { echo -e "  ${YELLOW}[!]${NC} $1"; }
fail() { echo -e "  ${RED}[✗]${NC} $1"; }
info() { echo -e "  ${CYAN}[i]${NC} $1"; }

section() {
    echo ""
    echo -e "${GREEN}${BOLD}  ┏━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┓${NC}"
    echo -e "${GREEN}${BOLD}  ┃  $1${NC}"
    echo -e "${GREEN}${BOLD}  ┗━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┛${NC}"
}

matrix_rain() {
    local cols; cols=$(tput cols 2>/dev/null || echo 80)
    local chars="NIGHTCRAWLER01010101"
    tput civis 2>/dev/null
    for ((l=0; l<5; l++)); do
        local line=""
        for ((c=0; c<cols; c++)); do
            [ $((RANDOM % 3)) -eq 0 ] && line+="\033[32m${chars:$((RANDOM % ${#chars})):1}" || line+=" "
        done
        echo -e "$line"; sleep 0.04
    done
    tput cnorm 2>/dev/null; sleep 0.1
    echo -e "${NC}"
}

glitch_text() {
    local text="$1" glitch_chars="@#\$%&!?*~^"
    for ((pass=0; pass<2; pass++)); do
        local glitched=""
        for ((i=0; i<${#text}; i++)); do
            [ $((RANDOM % 4)) -eq 0 ] && glitched+="${glitch_chars:$((RANDOM % ${#glitch_chars})):1}" || glitched+="${text:$i:1}"
        done
        printf "\r  ${GREEN}%s${NC}" "$glitched"; sleep 0.08
    done
    printf "\r  ${GREEN}${BOLD}%s${NC}\n" "$text"
}

spinner() {
    local pid=$1 msg="${2:-Processing}" spin='⠋⠙⠹⠸⠼⠴⠦⠧⠇⠏' i=0
    tput civis 2>/dev/null
    while kill -0 "$pid" 2>/dev/null; do
        printf "\r  ${CYAN}[%s]${NC} %s..." "${spin:i++%${#spin}:1}" "$msg"; sleep 0.1
    done
    printf "\r  ${GREEN}[✓]${NC} %-50s\n" "$msg"
    tput cnorm 2>/dev/null
}

# ── BANNER ───────────────────────────────────────────────────────
banner() {
    clear; echo ""
    echo -e "${GREEN}${BOLD}"
    cat << 'BANNER'
                     ╲  ╲ │ ╱  ╱
                      ╲  ╲│╱  ╱
                   ╺━━━[◉ ◉]━━━╸
                      ╱  ╱│╲  ╲
                     ╱  ╱ │ ╲  ╲

  ╔═══════════════════════════════════════════════════════════╗
  ║  ███╗   ██╗██╗ ██████╗ ██╗  ██╗████████╗               ║
  ║  ████╗  ██║██║██╔════╝ ██║  ██║╚══██╔══╝               ║
  ║  ██╔██╗ ██║██║██║  ███╗███████║   ██║                   ║
  ║  ██║╚██╗██║██║██║   ██║██╔══██║   ██║                   ║
  ║  ██║ ╚████║██║╚██████╔╝██║  ██║   ██║                   ║
  ║  ╚═╝  ╚═══╝╚═╝ ╚═════╝ ╚═╝  ╚═╝   ╚═╝                  ║
  ║         ██████╗██████╗  █████╗ ██╗    ██╗██╗     ███████╗██████╗  ║
  ║        ██╔════╝██╔══██╗██╔══██╗██║    ██║██║     ██╔════╝██╔══██╗ ║
  ║        ██║     ██████╔╝███████║██║ █╗ ██║██║     █████╗  ██████╔╝ ║
  ║        ██║     ██╔══██╗██╔══██║██║███╗██║██║     ██╔══╝  ██╔══██╗ ║
  ║        ╚██████╗██║  ██║██║  ██║╚███╔███╔╝███████╗███████╗██║  ██║ ║
  ║         ╚═════╝╚═╝  ╚═╝╚═╝  ╚═╝ ╚══╝╚══╝╚══════╝╚══════╝╚═╝  ╚═╝║
  ╚═══════════════════════════════════════════════════════════╝
BANNER
    echo -e "${NC}"
    echo -e "    ${DIM}v7.0 | Offensive Security Framework | by 1607-NetEnginee / Cyberoutcast${NC}"
    echo ""
    [ -n "$OPERATOR_NAME" ] && echo -e "    ${DIM}Operator  : ${WHITE}$OPERATOR_NAME${NC}"
    [ -n "$INSTANSI_NAME" ] && echo -e "    ${DIM}Instansi  : ${WHITE}$INSTANSI_NAME${NC}"
    [ ${#TARGETS[@]} -gt 0 ] && echo -e "    ${DIM}Target(s) : ${WHITE}${TARGETS[*]}${NC}"
    [ "$STEALTH_MODE" = "true" ] && echo -e "    ${DIM}Stealth   : ${GREEN}ACTIVE${NC}" || echo -e "    ${DIM}Stealth   : ${RED}DISABLED${NC}"
    echo ""
}

# ── SANITIZE DOMAIN ──────────────────────────────────────────────
sanitize_domain() {
    echo "$1" | sed 's|https\?://||g;s|/.*||g' | tr -d '[:space:]' | \
        grep -oP '^[a-zA-Z0-9][a-zA-Z0-9._-]+[a-zA-Z0-9]$' || echo ""
}

# ── RISK SCORING ─────────────────────────────────────────────────
calc_risk_score() {
    local raw=$(( RISK_CRITICAL * 25 + RISK_HIGH * 10 + RISK_MEDIUM * 4 + RISK_LOW * 1 ))
    [ "$raw" -gt 100 ] && echo 100 || echo "$raw"
}
get_risk_level() {
    local s=$1
    if   [ "$s" -gt 75 ]; then echo "CRITICAL"
    elif [ "$s" -gt 50 ]; then echo "HIGH"
    elif [ "$s" -gt 25 ]; then echo "MEDIUM"
    elif [ "$s" -gt 10 ]; then echo "LOW"
    else echo "SECURE"; fi
}
get_risk_color() {
    local s=$1
    if   [ "$s" -gt 75 ]; then echo "#ff2222"
    elif [ "$s" -gt 50 ]; then echo "#ff6600"
    elif [ "$s" -gt 25 ]; then echo "#ffaa00"
    elif [ "$s" -gt 10 ]; then echo "#ffdd00"
    else echo "#00ff41"; fi
}

# ── SESSION INIT ─────────────────────────────────────────────────
input_setup() {
    matrix_rain; banner

    section "SESSION INITIALIZATION"
    echo ""
    echo -ne "  ${CYAN}[>]${NC} Operator / Team Name  : "; read -r OPERATOR_NAME
    [ -z "$OPERATOR_NAME" ] && OPERATOR_NAME="NightOps"
    echo -ne "  ${CYAN}[>]${NC} Klien / Instansi       : "; read -r INSTANSI_NAME
    [ -z "$INSTANSI_NAME" ] && INSTANSI_NAME="Undisclosed"

    echo ""
    section "TARGET ACQUISITION"
    echo ""
    echo -e "  ${DIM}Masukkan target satu per satu. Ketik ${WHITE}done${DIM} jika sudah selesai.${NC}"
    echo ""
    local idx=1
    while true; do
        echo -ne "  ${CYAN}[target-$idx]${NC} > "; read -r raw_input
        [[ "$raw_input" =~ ^(done|selesai|q|)$ ]] && break
        local clean; clean=$(sanitize_domain "$raw_input")
        if [ -n "$clean" ]; then
            TARGETS+=("$clean"); ok "Target diterima: $clean"; idx=$((idx+1))
        else
            warn "Format tidak valid. Contoh: example.com"
        fi
    done
    [ ${#TARGETS[@]} -eq 0 ] && { fail "Tidak ada target. Keluar."; exit 1; }

    REPORT_DIR="$OUTPUT_DIR/${INSTANSI_NAME// /_}_$TIMESTAMP"
    SCAN_LOG="$REPORT_DIR/scan.log"
    mkdir -p "$REPORT_DIR"

    echo ""
    glitch_text "${#TARGETS[@]} target terkunci."
    echo -e "  ${DIM}Laporan: $REPORT_DIR${NC}"; echo ""

    echo -ne "  ${CYAN}[>]${NC} Stealth mode? [Y/n]: "; read -r sc
    [[ "$sc" =~ ^[Nn]$ ]] && STEALTH_MODE="false" || STEALTH_MODE="true"
    [ "$STEALTH_MODE" = "true" ] && ok "Stealth: ${GREEN}AKTIF${NC}" || warn "Stealth: NONAKTIF"

    echo ""
    echo -ne "  ${CYAN}[>]${NC} Proxy (kosong = skip): "; read -r pi
    [ -n "$pi" ] && { PROXY="$pi"; ok "Proxy: $PROXY"; }

    echo ""
    echo -ne "  ${YELLOW}[!]${NC} Mulai scan? [Y/n]: "; read -r CONFIRM
    [[ "$CONFIRM" =~ ^[Nn]$ ]] && { echo "  Dibatalkan."; exit 0; }
    banner
}

# ── PARSE FINDINGS FROM v7 OUTPUT ────────────────────────────────
parse_findings() {
    local logfile="$1"
    [ ! -f "$logfile" ] && return

    RISK_CRITICAL=0; RISK_HIGH=0; RISK_MEDIUM=0; RISK_LOW=0; RISK_INFO=0
    FINDINGS_DB=()

    while IFS= read -r line; do
        # Parse format: level=xxx title="xxx" resource="xxx"
        local level title resource plugin
        level=$(echo "$line"   | grep -oP 'level=\K\w+' | head -1)
        title=$(echo "$line"   | grep -oP 'title="\K[^"]+' | head -1)
        resource=$(echo "$line" | grep -oP 'resource="\K[^"]+' | head -1)
        plugin=$(echo "$line"  | grep -oP 'plugin=\K\w+' | head -1)

        [ -z "$title" ] && continue

        case "$level" in
            critical) RISK_CRITICAL=$((RISK_CRITICAL+1)); FINDINGS_DB+=("CRITICAL|$plugin|$title|$resource") ;;
            high)     RISK_HIGH=$((RISK_HIGH+1));     FINDINGS_DB+=("HIGH|$plugin|$title|$resource") ;;
            medium)   RISK_MEDIUM=$((RISK_MEDIUM+1)); FINDINGS_DB+=("MEDIUM|$plugin|$title|$resource") ;;
            low)      RISK_LOW=$((RISK_LOW+1));       FINDINGS_DB+=("LOW|$plugin|$title|$resource") ;;
            info|*)   RISK_INFO=$((RISK_INFO+1));     FINDINGS_DB+=("INFO|$plugin|$title|$resource") ;;
        esac
    done < <(grep " finding " "$logfile" 2>/dev/null)
}

# ── RUN SCAN ─────────────────────────────────────────────────────
run_scan() {
    local profile="${1:-default}"
    local plugins="${2:-}"

    section "MENJALANKAN SCAN — profile: $profile"
    echo ""

    local nc_args=("--profile" "$profile" "--operator" "$OPERATOR_NAME" "--client" "$INSTANSI_NAME")
    [ -n "$plugins" ] && nc_args+=("--plugins" "$plugins")

    for target in "${TARGETS[@]}"; do
        info "Target: $target"
        local target_log="$REPORT_DIR/${target//./_}_scan.log"

        local nc_cmd=("$NC_BIN" "scan" "-t" "$target" "${nc_args[@]}" "-o" "$REPORT_DIR" "-f" "ndjson")

        echo "" >> "$SCAN_LOG" 2>/dev/null
        echo "=== SCAN: $target | $(date) ===" >> "$SCAN_LOG"

        # Run scan, capture output to log dan tampilkan di terminal
        "${nc_cmd[@]}" 2>&1 | tee -a "$SCAN_LOG" "$target_log"
        echo ""
    done

    parse_findings "$SCAN_LOG"
    generate_html_report
    show_summary
}

# ── SUMMARY ──────────────────────────────────────────────────────
show_summary() {
    local risk_score; risk_score=$(calc_risk_score)
    local risk_level; risk_level=$(get_risk_level "$risk_score")

    echo ""
    section "✅ SCAN SELESAI"
    echo ""
    echo -e "  ${DIM}Risk Score : ${WHITE}${risk_score}/100 (${risk_level})${NC}"
    echo -e "  ${RED}Critical   : $RISK_CRITICAL${NC}"
    echo -e "  ${YELLOW}High       : $RISK_HIGH${NC}"
    echo -e "  ${YELLOW}Medium     : $RISK_MEDIUM${NC}"
    echo -e "  ${GREEN}Low        : $RISK_LOW${NC}"
    echo -e "  ${DIM}Info       : $RISK_INFO${NC}"
    echo ""
    ok "Laporan HTML : $REPORT_DIR/NIGHTCRAWLER_REPORT.html"
    echo ""

    # Buka laporan di browser jika ada
    if command -v xdg-open &>/dev/null; then
        echo -ne "  ${CYAN}[>]${NC} Buka laporan di browser? [Y/n]: "; read -r ob
        [[ ! "$ob" =~ ^[Nn]$ ]] && xdg-open "$REPORT_DIR/NIGHTCRAWLER_REPORT.html" 2>/dev/null &
    fi
}

# ══════════════════════════════════════════════════════════════════
#  GENERATE INTERACTIVE HTML REPORT
# ══════════════════════════════════════════════════════════════════
generate_html_report() {
    local REPORT_HTML="$REPORT_DIR/NIGHTCRAWLER_REPORT.html"
    local risk_score; risk_score=$(calc_risk_score)
    local risk_level; risk_level=$(get_risk_level "$risk_score")
    local risk_color; risk_color=$(get_risk_color "$risk_score")

    # Hitung arc gauge
    local arc_angle=$((risk_score * 180 / 100))
    local rad_end; rad_end=$(awk "BEGIN{printf \"%.6f\", 3.14159265 - ($arc_angle * 3.14159265 / 180)}")
    local x_end; x_end=$(awk "BEGIN{printf \"%.2f\", 100 + 80 * cos($rad_end)}")
    local y_end; y_end=$(awk "BEGIN{printf \"%.2f\", 100 - 80 * sin($rad_end)}")
    local large_arc; large_arc=$([ "$arc_angle" -gt 180 ] && echo 1 || echo 0)

    # Build findings JSON untuk JavaScript
    local findings_json="["
    local first=1
    for f in "${FINDINGS_DB[@]}"; do
        local f_level f_plugin f_title f_resource
        f_level=$(echo "$f"    | cut -d'|' -f1)
        f_plugin=$(echo "$f"   | cut -d'|' -f2)
        f_title=$(echo "$f"    | cut -d'|' -f3 | sed 's/"/\\"/g')
        f_resource=$(echo "$f" | cut -d'|' -f4 | sed 's/"/\\"/g')
        [ "$first" -eq 1 ] && first=0 || findings_json+=","
        findings_json+="{\"level\":\"$f_level\",\"plugin\":\"$f_plugin\",\"title\":\"$f_title\",\"resource\":\"$f_resource\"}"
    done
    findings_json+="]"

    # Build scan log content
    local log_content=""
    [ -f "$SCAN_LOG" ] && log_content=$(sed 's/</\&lt;/g;s/>/\&gt;/g;s/\x1b\[[0-9;]*m//g' "$SCAN_LOG" | tail -200)

    cat > "$REPORT_HTML" << HTMLEOF
<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>NIGHTCRAWLER Report — ${INSTANSI_NAME}</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@300;400;500;600;700&display=swap');

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
    --bg:      #080c08;
    --bg2:     #0d110d;
    --bg3:     #121812;
    --bg4:     #161e16;
    --border:  #1a2a1a;
    --border2: #22332a;
    --green:   #00ff41;
    --green2:  #39ff14;
    --green3:  #00cc33;
    --cyan:    #00e5ff;
    --red:     #ff2244;
    --orange:  #ff6600;
    --yellow:  #ffcc00;
    --text:    #b0c8b0;
    --text2:   #607060;
    --text3:   #405040;
}

body {
    font-family: 'JetBrains Mono', 'Courier New', monospace;
    background: var(--bg);
    color: var(--text);
    font-size: 13px;
    line-height: 1.6;
    min-height: 100vh;
}

/* Scanline overlay */
